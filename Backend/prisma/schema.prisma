// Backend/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/* =========================
   ENUMS (from your doc)
   ========================= */
enum trip_status {
  OPEN
  FULL
  CANCELED
  CLOSED
  COMPLETED
}

enum participant_role {
  LEADER
  MEMBER
}

enum participant_status {
  JOINED
  LEFT
  KICKED
}

enum receipt_status {
  PENDING
  CONFIRMED
}

enum settlement_status {
  REQUESTED
  PAID_SELF
  CONFIRMED
  DISPUTED
  OVERDUE
  CANCELED
}

enum verification_status {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
}

enum report_status {
  OPEN
  REVIEWED
  ACTIONED
}

/* =========================
   1) users
   ========================= */
model users {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique
  email_verified  Boolean  @default(false)
  nickname        String   @unique @db.VarChar(20)
  profile_img_url String?  @db.Text
  trust_score     Decimal  @default(36.5) @db.Decimal(3, 1)
  penalty_points  Int      @default(0)
  is_suspended    Boolean  @default(false)
  suspended_until DateTime?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  // relations
  email_verifications email_verifications[]
  trips_created       trips[] @relation("trips_creator")
  trips_led           trips[] @relation("trips_leader")
  trip_participants   trip_participants[]

  payment_channels_edited payment_channels[] @relation("payment_channels_editor")

  receipts_uploaded receipts[] @relation("receipts_uploader")

  settlements_paid settlements[] @relation("settlements_payer")
  settlements_received settlements[] @relation("settlements_payee")

  settlement_proofs_uploaded settlement_proofs[] @relation("settlement_proofs_uploader")

  chat_messages_sent chat_messages[]

  reviews_written reviews[] @relation("reviews_from")
  reviews_received reviews[] @relation("reviews_to")

  penalties penalties[]
  reports_made reports[] @relation("reports_reporter")
  reports_received reports[] @relation("reports_reported")
}

/* =========================
   2) email_verifications
   ========================= */
model email_verifications {
  id          String              @id @default(uuid()) @db.Uuid
  user_id     String?             @db.Uuid
  email       String
  code_hash   String              @db.Text
  status      verification_status @default(PENDING)
  expires_at  DateTime            @db.Timestamptz(6)
  verified_at DateTime?           @db.Timestamptz(6)
  created_at  DateTime            @default(now()) @db.Timestamptz(6)

  user users? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([email])
}

/* =========================
   3) trips
   ========================= */
model trips {
  id              String      @id @default(uuid()) @db.Uuid
  creator_user_id String      @db.Uuid
  leader_user_id  String      @db.Uuid

  depart_name String   @db.VarChar(80)
  depart_lat  Decimal  @db.Decimal(9, 6)
  depart_lng  Decimal  @db.Decimal(9, 6)

  arrive_name String   @db.VarChar(80)
  arrive_lat  Decimal  @db.Decimal(9, 6)
  arrive_lng  Decimal  @db.Decimal(9, 6)

  depart_time    DateTime    @db.Timestamptz(6)
  capacity       Int
  status         trip_status @default(OPEN)
  estimated_fare Int?

  created_at DateTime @default(now()) @db.Timestamptz(6)

  creator users @relation("trips_creator", fields: [creator_user_id], references: [id], onDelete: Restrict)
  leader  users @relation("trips_leader", fields: [leader_user_id], references: [id], onDelete: Restrict)

  trip_participants trip_participants[]
  payment_channels  payment_channels?
  receipts          receipts?
  chat_rooms        chat_rooms?
  settlements       settlements[]
  reviews           reviews[]
  penalties         penalties[]
  reports           reports[]

  @@index([depart_time])
  @@index([status])
}

/* =========================
   4) trip_participants
   ========================= */
model trip_participants {
  id                  String             @id @default(uuid()) @db.Uuid
  trip_id             String             @db.Uuid
  user_id             String             @db.Uuid
  role                participant_role   @default(MEMBER)
  status              participant_status @default(JOINED)
  confirmed_departure Boolean            @default(false)
  joined_at           DateTime           @default(now()) @db.Timestamptz(6)
  left_at             DateTime?          @db.Timestamptz(6)

  trip trips @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([trip_id, user_id])
  @@index([user_id])
}

/* =========================
   5) payment_channels (KakaoPay only)
   ========================= */
model payment_channels {
  id           String   @id @default(uuid()) @db.Uuid
  trip_id      String   @unique @db.Uuid
  kakaopay_link String? @db.Text
  updated_by   String   @db.Uuid
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  trip   trips @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  editor users @relation("payment_channels_editor", fields: [updated_by], references: [id], onDelete: Restrict)
}

/* =========================
   6) receipts
   ========================= */
model receipts {
  id          String        @id @default(uuid()) @db.Uuid
  trip_id     String        @unique @db.Uuid
  uploaded_by String        @db.Uuid
  image_url   String        @db.Text
  total_amount Int
  status      receipt_status @default(PENDING)
  confirmed_at DateTime?    @db.Timestamptz(6)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)

  trip     trips @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  uploader users @relation("receipts_uploader", fields: [uploaded_by], references: [id], onDelete: Restrict)

  settlements settlements[]
}

/* =========================
   7) settlements
   ========================= */
model settlements {
  id            String           @id @default(uuid()) @db.Uuid
  trip_id       String           @db.Uuid
  receipt_id    String           @db.Uuid
  payer_user_id String           @db.Uuid
  payee_user_id String           @db.Uuid
  share_amount  Int
  memo_code     String?          @db.VarChar(20)

  status       settlement_status @default(REQUESTED)
  requested_at DateTime          @default(now()) @db.Timestamptz(6)
  paid_self_at DateTime?         @db.Timestamptz(6)
  confirmed_at DateTime?         @db.Timestamptz(6)
  due_at       DateTime?         @db.Timestamptz(6)

  trip    trips    @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  receipt receipts @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  payer users @relation("settlements_payer", fields: [payer_user_id], references: [id], onDelete: Restrict)
  payee users @relation("settlements_payee", fields: [payee_user_id], references: [id], onDelete: Restrict)

  settlement_proofs settlement_proofs[]

  @@unique([receipt_id, payer_user_id])
  @@index([trip_id])
  @@index([payee_user_id])
}

/* =========================
   8) settlement_proofs
   ========================= */
model settlement_proofs {
  id            String   @id @default(uuid()) @db.Uuid
  settlement_id String   @db.Uuid
  uploaded_by   String   @db.Uuid
  image_url     String   @db.Text
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  settlement settlements @relation(fields: [settlement_id], references: [id], onDelete: Cascade)
  uploader   users       @relation("settlement_proofs_uploader", fields: [uploaded_by], references: [id], onDelete: Restrict)

  @@index([settlement_id])
}

/* =========================
   9) chat_rooms
   ========================= */
model chat_rooms {
  id         String   @id @default(uuid()) @db.Uuid
  trip_id    String   @unique @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  trip trips @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  chat_messages chat_messages[]
}

/* =========================
   10) chat_messages
   ========================= */
model chat_messages {
  id             String   @id @default(uuid()) @db.Uuid
  room_id        String   @db.Uuid
  sender_user_id String   @db.Uuid
  message        String   @db.Text
  sent_at        DateTime @default(now()) @db.Timestamptz(6)

  room   chat_rooms @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender users      @relation(fields: [sender_user_id], references: [id], onDelete: Cascade)

  @@index([room_id, sent_at])
}

/* =========================
   11) reviews
   ========================= */
model reviews {
  id           String  @id @default(uuid()) @db.Uuid
  trip_id      String  @db.Uuid
  from_user_id String  @db.Uuid
  to_user_id   String  @db.Uuid
  rating       Int
  tags         Json?
  comment      String? @db.VarChar(200)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  trip trips @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  from users @relation("reviews_from", fields: [from_user_id], references: [id], onDelete: Cascade)
  to   users @relation("reviews_to", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@unique([trip_id, from_user_id, to_user_id])
  @@index([to_user_id])
}

/* =========================
   12) penalties
   ========================= */
model penalties {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  trip_id    String?  @db.Uuid
  type       String   @db.VarChar(30)
  points     Int
  reason     String?  @db.VarChar(200)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trip trips? @relation(fields: [trip_id], references: [id], onDelete: SetNull)

  @@index([user_id])
}

/* =========================
   13) reports
   ========================= */
model reports {
  id               String       @id @default(uuid()) @db.Uuid
  trip_id           String?      @db.Uuid
  reporter_user_id  String       @db.Uuid
  reported_user_id  String       @db.Uuid
  reason           String       @db.VarChar(50)
  detail           String?      @db.Text
  status           report_status @default(OPEN)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)

  trip     trips? @relation(fields: [trip_id], references: [id], onDelete: SetNull)
  reporter users  @relation("reports_reporter", fields: [reporter_user_id], references: [id], onDelete: Cascade)
  reported users  @relation("reports_reported", fields: [reported_user_id], references: [id], onDelete: Cascade)

  @@index([reported_user_id])
}